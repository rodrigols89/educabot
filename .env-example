# .env

##############################################################################
#                                                                            #
#                            CONFIGURAÇÕES DO SERVIDOR                       #
#                                                                            #
# Define como a Evolution API será iniciada e disponibilizada na rede.       #
# Essas configurações controlam o protocolo utilizado, a porta do servidor   #
# e a URL base usada pela própria aplicação para gerar links e callbacks.    #
#                                                                            #
##############################################################################

SERVER_NAME=evolution                           # Nome interno da aplicação
SERVER_TYPE=http                                # Protocolo utilizado (http ou https)
SERVER_PORT=8080                                # Porta da Evolution API
SERVER_URL=http://localhost:8080                # URL base da aplicação


##############################################################################
#                                                                            #
#                             CONFIGURAÇÃO DE WEBHOOK                        #
#                                                                            #
# Controla o envio automático de eventos da Evolution API para sistemas      #
# externos. Quando habilitado, a API envia requisições HTTP sempre que       #
# determinados eventos acontecerem, como o recebimento de mensagens.         #
#                                                                            #
##############################################################################

WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_EVENTS_MESSAGES_UPSERT=true


##############################################################################
#                                                                            #
#                              CONFIGURAÇÃO DE CACHE                         #
#                                                                            #
# Define como a Evolution API armazena dados temporários para melhorar       #
# o desempenho. Neste projeto o Redis é utilizado como sistema de cache,     #
# enquanto o cache local em memória permanece desabilitado.                  #
#                                                                            #
##############################################################################

CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/6
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false

CACHE_LOCAL_ENABLED=false


##############################################################################
#                                                                            #
#                           CONFIGURAÇÃO DA SESSÃO WHATSAPP                  #
#                                                                            #
# Define informações utilizadas durante a criação da sessão do WhatsApp.     #
# A versão do aplicativo influencia a compatibilidade com a biblioteca       #
# utilizada pela Evolution API.                                              #
#                                                                            #
##############################################################################

CONFIG_SESSION_PHONE_VERSION=


##############################################################################
#                                                                            #
#                             AUTENTICAÇÃO DA API                            #
#                                                                            #
# Chave utilizada para autenticar chamadas à Evolution API. Apenas clientes  #
# que possuírem esta chave poderão acessar os endpoints protegidos.          #
#                                                                            #
##############################################################################

AUTHENTICATION_API_KEY=


##############################################################################
#                                                                            #
#                           CONFIGURAÇÃO DO BANCO DE DADOS                   #
#                                                                            #
# Define qual banco de dados será utilizado pela Evolution API e como ela    #
# deverá se conectar a ele.                                                  #
#                                                                            #
##############################################################################

DATABASE_PROVIDER=

# String de conexão utilizada pela Evolution API.
# Formato:
# banco://usuario:senha@host:porta/banco
DATABASE_CONNECTION_URI=

# String utilizada pelo sistema (SQLAlchemy).
# Formato:
# dialect+driver://usuario:senha@host:porta/banco
DATABASE_URL=


##############################################################################
#                                                                            #
#                         CONFIGURAÇÃO DA EVOLUTION API                      #
#                                                                            #
# Define qual instância da Evolution API será utilizada pelo sistema e qual  #
# endereço deve ser utilizado para realizar chamadas internas à API.         #
#                                                                            #
##############################################################################

EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_INSTANCE=


##############################################################################
#                                                                            #
#                       FORNECEDOR DE GÁS                                    #
#                                                                            #
# Dados do fornecedor responsável pelo atendimento dos pedidos de gás.       #
# Essas informações são utilizadas para encaminhar automaticamente os        #
# pedidos realizados pelos usuários.                                         #
#                                                                            #
##############################################################################

SUPPLIER_GAS_NAME=
SUPPLIER_GAS_PHONE=


##############################################################################
#                                                                            #
#                      FORNECEDOR DE ÁGUA                                    #
#                                                                            #
# Dados do fornecedor responsável pelos pedidos comuns de água.              #
#                                                                            #
##############################################################################

SUPPLIER_WATER_NAME=
SUPPLIER_WATER_PHONE=


##############################################################################
#                                                                            #
#                FORNECEDOR DE ÁGUA DA SECRETARIA                            #
#                                                                            #
# Dados do fornecedor responsável exclusivamente pelos pedidos de água       #
# realizados pela Secretaria. Isso permite utilizar um fornecedor diferente  #
# para esse tipo específico de solicitação.                                  #
#                                                                            #
##############################################################################

SUPPLIER_SECRETARIAT_WATER_NAME=
SUPPLIER_SECRETARIAT_WATER_PHONE=
SECRETARIAT_PHONES=
